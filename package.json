{
  "name": "@phobos-lsx/lsx",
  "version": "2.0.0-alpha.9",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "lerna": "lerna",
    "build": "lerna run build",
    "build:elements": "npm run build -w libs/phobos-elements",
    "build:protocol": "npm run build -w libs/protocol",
    "k8s:build": "docker build -t prim/phobos-lsx:%npm_package_version% -t prim/phobos-lsx:latest .",
    "k8s:deploy": "helm upgrade --install phobos-lsx ./k8s",
    "k8s:status": "helm status phobos-lsx",
    "release": "release-it --workspaces",
    "release:pre": "npm run release -- --preRelease=alpha --no-git --no-github",
    "mirrord:frontend": "mirrord exec --config-file .mirrord/mirrord.json --target deployment/phobos-lsx-deployment -- npm run start:frontend",
    "start:frontend": "npm run start -w apps/frontend",
    "start:frontend:dev": "npm run start:dev -w apps/frontend",
    "start:backend": "npm run start -w apps/backend",
    "start:backend:dev": "npm run start:dev -w apps/backend"
  },
  "dependencies": {
    "@release-it/bumper": "^7.0.5",
    "release-it": "^19.2.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.1.3",
    "@angular/build": "20.1.3",
    "@angular/cli": "20.1.3",
    "@angular/compiler-cli": "20.1.3",
    "lerna": "^9.0.5",
    "vite": "^7.1.2"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "github": {
      "release": true
    },
    "git": {
      "requireCleanWorkingDir": false
    },
    "npm": {
      "publish": false,
      "bump": false
    },
    "plugins": {
      "@release-it/bumper": {
        "out": [
          "apps/*/package.json",
          {
            "file": "k8s/Chart.yaml",
            "path": "version"
          },
          {
            "file": "k8s/Chart.yaml",
            "path": "appVersion"
          }
        ]
      }
    },
    "hooks": {
      "after:release": [
        "docker build -t prim/phobos-lsx:${version} -t prim/phobos-lsx:latest ."
      ]
    }
  }
}
